# Keep the build context (and image) lean. The build stage runs `npm ci` + the
# SvelteKit build itself, so none of the generated/local artifacts below belong
# in the context.
node_modules
build
.svelte-kit
.venv
venv
.git
.gitignore
.github

# Tests / e2e / coverage — not needed to build or run the app.
tests
test-results
playwright-report
e2e
coverage

# Local / editor / OS cruft
.DS_Store
*.log
.env
.env.*
.vscode
.idea
.cellar
*.ipynb_checkpoints

# Docs / packaging that don't affect the image build
docs
data
*.md
!README.md
